{
  "compilerOptions": {
    "module": "CommonJS",            // Thay đổi từ nodenext
    "moduleResolution": "node",       // Thay đổi từ nodenext
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2022",              // NestJS 11 chạy rất tốt với bản này
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "incremental": false,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "baseUrl": "./",
    "types": ["node", "multer"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}